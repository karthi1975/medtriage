# Railway Environment Variables Template
# Copy these to your Railway service's environment variables

# ===========================================
# OpenAI Configuration (REQUIRED)
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# ===========================================
# FHIR Server Configuration (REQUIRED)
# ===========================================
# Option 1: Use public FHIR server (for testing)
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4

# Option 2: Use your Railway-deployed HAPI FHIR (recommended for production)
# FHIR_SERVER_URL=https://your-hapi-fhir.railway.app/fhir

# ===========================================
# Tribal Knowledge Database (REQUIRED)
# Use Railway's variable references
# ===========================================
TRIBAL_DB_HOST=${{postgres-tribal.PGHOST}}
TRIBAL_DB_PORT=${{postgres-tribal.PGPORT}}
TRIBAL_DB_NAME=${{postgres-tribal.PGDATABASE}}
TRIBAL_DB_USER=${{postgres-tribal.PGUSER}}
TRIBAL_DB_PASSWORD=${{postgres-tribal.PGPASSWORD}}

# Alternative: Use full DATABASE_URL if provided by Railway
# DATABASE_URL=${{postgres-tribal.DATABASE_URL}}

# ===========================================
# RAG Configuration (OPTIONAL)
# ===========================================
USE_RAG=True

# ===========================================
# API Configuration (OPTIONAL)
# ===========================================
API_TITLE=MediChat FHIR Triage & Scheduling API
API_VERSION=2.0.0
API_DESCRIPTION=AI-powered medical triage with intelligent appointment scheduling

# ===========================================
# Server Configuration (AUTO-SET by Railway)
# ===========================================
# PORT is automatically set by Railway, no need to add it
# Railway will inject: PORT=${{PORT}}

# ===========================================
# Frontend Configuration
# Add this to your frontend service
# ===========================================
# REACT_APP_API_URL=https://your-backend-service.railway.app
